{
  "name": "create-litmdx",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "create-litmdx": "./dist/bin/create.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp -r assets dist/assets",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": ["dist", "assets"],
  "dependencies": {
    "@types/prompts": "^2.4.9",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
