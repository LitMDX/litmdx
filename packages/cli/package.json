{
  "name": "litmdx",
  "version": "0.1.4",
  "type": "module",
  "bin": {
    "litmdx": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp -r template dist/template",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.template.json --noEmit",
    "lint": "eslint src template",
    "lint:fix": "eslint src template --fix",
    "format": "prettier --write src template",
    "format:check": "prettier --check src template",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@litmdx/core": "^0.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "mermaid": "^11.13.0",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.8.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.9.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
