# Canonical base URL of the site (used for sitemap.xml and OpenGraph).
LITMDX_SITE_URL=https://litmdx.dev

# URL to the GitHub repository (shown in the navbar).
LITMDX_GITHUB_URL=https://github.com/LitMDX/litmdx

# URL of the running @litmdx/agent server.
# Start the agent: npx @litmdx/agent
# Default: http://localhost:8000
LITMDX_AGENT_URL=http://localhost:8000
